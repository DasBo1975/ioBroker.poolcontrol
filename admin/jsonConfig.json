                "size": 4,
                "newLine": true,
                "xs": 12,
                "sm": 12,
                "md": 12,
                "lg": 12,
                "xl": 12
            },
            "helpLink_en": {
              "type": "staticLink",
              "label": "Open documentation (English) on GitHub",
              "href": "https://github.com/DasBo1975/ioBroker.poolcontrol/blob/main/docs/en/help.md",
                "newLine": true,
                "xs": 12,
                "sm": 12,
                "md": 12,
                "lg": 12,
                "xl": 12
            },
            "helpLink_de": {
              "type": "staticLink",
              "label": "Open documentation (German) on GitHub",
              "href": "https://github.com/DasBo1975/ioBroker.poolcontrol/blob/main/docs/de/help.md",
              "xs": 12,
              "sm": 12,
              "md": 12,
              "lg": 12,
              "xl": 12
            },
            "helpText": {
                "type": "staticText",
                "text": "Here you will find the complete documentation and information about all settings. Additional information about future versions will follow.",
                "xs": 12,
                "sm": 12,
                "md": 12,
                "lg": 12,
                "xl": 12
            },

            "ai_info_header": {
                "type": "header",
                "text": "Important information about the AI system",
                "size": 4,
                "newLine": true,
                "xs": 12,
                "sm": 12,
                "md": 12,
                "lg": 12,
                "xl": 12
            },
            "ai_info_text": {
                "type": "staticText",
                "text": "The AI system (aiHelper & aiForecastHelper) retrieves weather data from Open-Meteo via HTTPS. It uses the geo-coordinates from the ioBroker system configuration (system.config › latitude/longitude). No data is stored or transmitted to third parties. Without valid geo-coordinates, the AI system cannot generate forecasts.",
                "newLine": true,
                "xs": 12,
                "sm": 12,
                "md": 12,
                "lg": 12,
                "xl": 12
            },

            "help_ai_info": {
                "type": "staticText",
                "text": "Note: The AI features are completely optional and can be disabled at any time via the 'ai.enabled' datapoint. Weather features (e.g. weather hints, pool tips, forecast for tomorrow) can also be individually enabled or disabled via 'ai.weather.switches.*'. The adapter uses the Open-Meteo service to generate weather data. For this, the geo-coordinates stored in ioBroker (latitude and longitude from system.config) are required.",
                "newLine": true,
                "xs": 12,
                "sm": 12,
                "md": 12,
                "lg": 12,
                "xl": 12
            },

            "info_internet_header": {
                "type": "header",
                "text": "Internet access & data protection",
                "size": 4,
                "newLine": true,
                "xs": 12,
                "sm": 12,
                "md": 12,
                "lg": 12,
                "xl": 12
            },
            "info_internet_text": {
                "type": "staticText",
                "text": "The PoolControl adapter works completely locally by default. Currently, only the AI features access weather data from Open-Meteo via encrypted HTTPS. Only the geo-coordinates stored in ioBroker (latitude and longitude) are transmitted. No additional data is stored or sent to third parties. Future optional internet services may be added, but they will always be clearly marked.",
                "newLine": true,
                "xs": 12,
                "sm": 12,
                "md": 12,
                "lg": 12,
                "xl": 12
            },

            "info_season_header": {
                "type": "header",
                "text": "Note about pool season",
                "size": 4,
                "newLine": true,
                "xs": 12,
                "sm": 12,
                "md": 12,
                "lg": 12,
                "xl": 12
            },
            "info_season_text": {
                "type": "staticText",
                "text": "Many automatic features (e.g. solar control, photovoltaic mode, AI weather logic and diagnostic functions) only operate when the pool season is active. The season status can be changed at any time via the 'status.season_active' datapoint or in the instance configuration.",
                "newLine": true,
                "xs": 12,
                "sm": 12,
                "md": 12,
                "lg": 12,
                "xl": 12
            },

            "info_speech_header": {
                "type": "header",
                "text": "Central speech output (speech.queue)",
                "size": 4,
                "newLine": true,
                "xs": 12,
                "sm": 12,
                "md": 12,
                "lg": 12,
                "xl": 12
            },
            "info_speech_text": {
                "type": "staticText",
                "text": "All text and speech outputs of the adapter – including AI forecasts, warnings, pump status, solar hints and diagnostic messages – are emitted via the central 'speech.queue' datapoint. This datapoint should be used for VIS displays, Alexa or Telegram outputs.",
                "newLine": true,
                "xs": 12,
                "sm": 12,
                "md": 12,
                "lg": 12,
                "xl": 12
            }
        }
    }
  }
